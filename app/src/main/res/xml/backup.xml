<?xml version="1.0" encoding="utf-8"?>

<!-- Android 11 and lower -->
<!-- https://developer.android.com/about/versions/12/behavior-changes-12#backup-restore -->
<full-backup-content>
	<include
		domain="sharedpref"
		path="."
		requireFlags="clientSideEncryption" />
	<include
		domain="database"
		path="."
		requireFlags="clientSideEncryption" />
	<include
		domain="file"
		path="."
		requireFlags="clientSideEncryption" />

    <exclude
        domain="sharedpref"
        path="fmd_encrypted_settings.xml" />
</full-backup-content>
