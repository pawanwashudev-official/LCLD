<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    tools:context=".ui.LockScreenMessage">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_security"
            app:tint="@color/gold_primary"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LCLD: DEVICE LOCKED"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="@color/gold_primary"/>

        <TextView
            android:id="@+id/textViewLockScreenMessage"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="This device is in Theft Mode. Please enter the recovery PIN to stop the alarm."
            android:padding="16dp"
            android:textSize="18sp"
            android:textAlignment="center"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/pinInputLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Recovery PIN"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/gold_primary"
            app:hintTextColor="@color/gold_primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTextPin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberPassword"
                android:maxLength="8"/>
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/buttonUnlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STOP THEFT MODE"
            android:backgroundTint="@color/gold_primary"
            android:textColor="@color/md_theme_onPrimary"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
