<resources>

    <!-- Base application theme. -->
    <!-- Generated with https://material-foundation.github.io/material-theme-builder/ -->
    <!-- Now lives in themes.xml. The "NoActionBar" part is removed from the generated code. -->
    <style name="Theme.Fmd" parent="AppTheme" />

    <style name="Theme.AppCompat.Translucent" parent="Theme.AppCompat.NoActionBar">
        <item name="android:background">#00000000</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation</item>
    </style>

    <style name="FMD.Text.SectionTitle" parent="Widget.AppCompat.TextView">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAlignment">textStart</item>
    </style>

    <style name="FMD.Text.Log.Title" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="FMD.Text.Log.Message" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="FMD.Text.Log.Date" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">monospace</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="Lcld.GlassCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardBackgroundColor">@color/lcld_glass_surface</item>
        <item name="strokeColor">@color/lcld_glass_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardElevation">3dp</item>
    </style>

    

    <!-- AboutLibraries requires Material3 with NoActionBar. -->
    <style name="CustomAboutLibrariesStyle" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>



    <style name="Theme.Fmd.Spectrum.Rose" parent="Theme.Fmd">
        <item name="colorPrimary">#A20E5A</item>
        <item name="colorPrimaryContainer">#FFD8E9</item>
    </style>

    <style name="Theme.Fmd.Spectrum.Orange" parent="Theme.Fmd">
        <item name="colorPrimary">#A14500</item>
        <item name="colorPrimaryContainer">#FFDCC8</item>
    </style>

    <style name="Theme.Fmd.Spectrum.Lime" parent="Theme.Fmd">
        <item name="colorPrimary">#3A7000</item>
        <item name="colorPrimaryContainer">#CCF79E</item>
    </style>

    <style name="Theme.Fmd.Spectrum.Teal" parent="Theme.Fmd">
        <item name="colorPrimary">#006A67</item>
        <item name="colorPrimaryContainer">#9CF1EC</item>
    </style>

    <style name="Theme.Fmd.Spectrum.Indigo" parent="Theme.Fmd">
        <item name="colorPrimary">#3F51B5</item>
        <item name="colorPrimaryContainer">#DDE1FF</item>
    </style>

    <style name="Theme.Fmd.Spectrum.Violet" parent="Theme.Fmd">
        <item name="colorPrimary">#6A1B9A</item>
        <item name="colorPrimaryContainer">#F0DBFF</item>
    </style>

</resources>
